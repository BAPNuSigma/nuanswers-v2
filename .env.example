# Copy this file to .env.local and fill in your real values.
# .env.local is ignored by git and will never be pushed to GitHub.

# OpenAI API key — required for the tutor to work.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: which OpenAI model the tutor uses. Defaults to gpt-4.1 if unset.
# Examples: gpt-4.1, gpt-4o, gpt-4o-mini.
OPENAI_MODEL=gpt-4.1

# Optional: which OpenAI model reads uploaded photos (homework, slides, etc.)
# and converts them to text for the tutor. Defaults to gpt-4o-mini if unset
# (cheap and accurate for text-heavy images).
OPENAI_VISION_MODEL=gpt-4o-mini

# Supabase project (database + auth)
# Find these at https://supabase.com/dashboard → your project → Settings → API Keys
# The anon key is safe to expose in browser code (Row Level Security protects data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_REPLACE_ME

# Optional: bypass the in-person tutoring hours blocker (Mon-Fri 9-11am ET).
# Set to "true" only when you need to demo the bot during those hours.
# Leave unset (or "false") for normal operation.
TUTORING_HOURS_DISABLED=false
