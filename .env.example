# Copy this file to .env.local and fill in your real values.
# .env.local is ignored by git and will never be pushed to GitHub.

# OpenAI API key — required for the tutor to work.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Supabase project (database + auth)
# Find these at https://supabase.com/dashboard → your project → Settings → API Keys
# The anon key is safe to expose in browser code (Row Level Security protects data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_REPLACE_ME
